# Copy this file to .env and fill in your real values.
# Never commit the .env file — it contains secrets.

# Your Discord bot token (from the Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token-here

# The ID of the Discord channel where weekly announcements and results reports are posted
DISCORD_ANNOUNCEMENT_CHANNEL_ID=your-announcement-channel-id-here

# The ID of the Discord channel where staff-only alerts are posted (e.g. the /setweek reminder)
DISCORD_STAFF_CHANNEL_ID=your-staff-channel-id-here

# Your Wise Old Man group ID
WOM_GROUP_ID=24973

# Your Wise Old Man group verification code
WOM_VERIFICATION_CODE=769-307-819
